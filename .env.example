BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=file:../../local.db

# NSSurge traffic collector (optional in development; required in production for POST)
NSSURGE_COLLECTOR_TOKEN=dev-token
NSSURGE_MAX_EVENT_BYTES=4194304
