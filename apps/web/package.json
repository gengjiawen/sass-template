{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "pnpm --dir ../.. --filter @my-better-t-app/db db:generate",
    "prisma:migrate:deploy": "pnpm --dir ../.. --filter @my-better-t-app/db db:migrate:deploy",
    "prebuild": "pnpm run prisma:generate && pnpm run prisma:migrate:deploy",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "fumadocs-mdx && pnpm run prisma:generate && pnpm run prisma:migrate:deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@my-better-t-app/api": "workspace:*",
    "@my-better-t-app/auth": "workspace:*",
    "@my-better-t-app/env": "workspace:*",
    "@prisma/client": "catalog:",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.91.0",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "^11.13.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-auth": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "catalog:",
    "fumadocs-core": "16.6.17",
    "fumadocs-mdx": "14.2.10",
    "fumadocs-ui": "16.6.17",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^3.6.2",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.3.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@my-better-t-app/config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:"
  }
