{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "pnpm --dir ../.. --filter @my-better-t-app/db db:generate",
    "prisma:migrate:deploy": "pnpm --dir ../.. --filter @my-better-t-app/db db:migrate:deploy",
    "prebuild": "pnpm run prisma:generate && pnpm run prisma:migrate:deploy",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "fumadocs-mdx && pnpm run prisma:generate && pnpm run prisma:migrate:deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@my-better-t-app/auth": "workspace:*",
    "@my-better-t-app/db": "workspace:*",
    "@my-better-t-app/env": "workspace:*",
    "@prisma/client": "catalog:",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.100.14",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "^11.17.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-auth": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "catalog:",
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "15.0.10",
    "fumadocs-ui": "16.9.3",
    "i18next": "^26.3.0",
    "jotai": "^2.20.0",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "shadcn": "^4.9.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.3.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@my-better-t-app/config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@types/node": "^25",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.5.0"
}
