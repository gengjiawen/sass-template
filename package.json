{
  "name": "my-better-t-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "check-types": "pnpm -r check-types",
    "dev:native": "pnpm --filter native dev",
    "dev:web": "pnpm --filter web dev",
    "db:push": "pnpm --filter @my-better-t-app/db db:push",
    "db:studio": "pnpm --filter @my-better-t-app/db db:studio",
    "db:generate": "pnpm --filter @my-better-t-app/db db:generate",
    "db:migrate": "pnpm --filter @my-better-t-app/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @my-better-t-app/db db:migrate:deploy",
    "db:local": "pnpm --filter @my-better-t-app/db db:local",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "oxlint && oxfmt --write",
    "prepare": "husky"
  },
  "dependencies": {
    "@my-better-t-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@my-better-t-app/config": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "catalog:",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,md,mdx}": "oxfmt --write"
  },
  "packageManager": "pnpm@11.5.0"
}
